{
  "name": "agent-code-reviewer",
  "displayName": "Claude Code Reviewer",
  "description": "Native code review UI for Claude Code — annotate code and push feedback via channels",
  "version": "0.1.0",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/etsd-tech/vscode-agent-reviewer"
  },
  "keywords": ["claude", "claude-code", "code-review", "channels", "mcp"],
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscodeReviewer.submitReview",
        "title": "Send Review to Claude Code",
        "icon": "$(send)"
      },
      {
        "command": "vscodeReviewer.clearComments",
        "title": "Clear Review Comments",
        "icon": "$(trash)"
      },
      {
        "command": "vscodeReviewer.createComment",
        "title": "Add Comment"
      },
      {
        "command": "vscodeReviewer.commentAndSubmit",
        "title": "Comment & Send All to Claude Code",
        "icon": "$(send)"
      },
      {
        "command": "vscodeReviewer.showSessions",
        "title": "Show Claude Code Sessions"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vscodeReviewer.submitReview",
          "group": "navigation"
        },
        {
          "command": "vscodeReviewer.clearComments",
          "group": "navigation"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "vscodeReviewer.createComment",
          "group": "inline"
        },
        {
          "command": "vscodeReviewer.commentAndSubmit",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Agent Review",
      "properties": {
        "vscodeReviewer.basePort": {
          "type": "number",
          "default": 47123,
          "description": "Starting port for session discovery scan"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.0"
  }
}
